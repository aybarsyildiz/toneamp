<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	 Copy this file to Secrets.plist (same folder) and paste your key.
	 Secrets.plist is gitignored — it stays on your machine and gets
	 bundled into your local builds only. NEVER commit a real key and
	 NEVER ship one in an App Store build; production uses a backend proxy.
	-->
	<key>AnthropicAPIKey</key>
	<string>sk-ant-REPLACE-ME</string>
	<!--
	 Production: deploy server/toneamp-proxy (see its README), then set
	 these two keys. When ToneProxyURL is present the app sends tone-engine
	 requests to the proxy with NO client-side key — AnthropicAPIKey above
	 becomes a dev-only fallback and can be deleted.
	-->
	<key>ToneProxyURL</key>
	<string>https://toneamp-proxy.REPLACE-ME.workers.dev</string>
	<key>ToneProxyToken</key>
	<string>REPLACE-ME-same-as-APP_TOKEN-secret</string>
</dict>
</plist>
